),

overall AS (
    SELECT 'overall' AS metric_type,
           NULL AS product_category,
           NULL AS seller_id,
           COUNT(DISTINCT order_id) AS total_orders,
           COUNT(DISTINCT CASE WHEN order_status = 'canceled' THEN order_id END) AS canceled_orders,
           ROUND(COUNT(DISTINCT CASE WHEN order_status = 'canceled' THEN order_id END) / COUNT(DISTINCT order_id), 4) AS return_rate,
           NULL AS rank,
           NULL AS review_score,
           NULL AS comment_count
    FROM ne_orders
),

order_items_expanded AS (
    SELECT oi.order_id,
           o.order_status,
           t.product_category_name_english AS product_category,
           oi.seller_id
    FROM ne_orders o
    JOIN order_items oi ON o.order_id = oi.order_id
    JOIN products p ON oi.product_id = p.product_id
    LEFT JOIN product_category_name_translation t ON p.product_category_name = t.product_category_name
),

category_seller_stats AS (
    SELECT 'category_seller' AS metric_type,
           COALESCE(product_category, 'Unknown') AS product_category,
           seller_id,
           COUNT(DISTINCT order_id) AS total_orders,
           COUNT(DISTINCT CASE WHEN order_status = 'canceled' THEN order_id END) AS canceled_orders,
           ROUND(COUNT(DISTINCT CASE WHEN order_status = 'canceled' THEN order_id END) / COUNT(DISTINCT order_id), 4) AS return_rate,
           NULL AS rank,
           NULL AS review_score,
           NULL AS comment_count
    FROM order_items_expanded
    GROUP BY product_category, seller_id
),

ranked AS (
    SELECT metric_type,
           product_category,
           seller_id,
           total_orders,
           canceled_orders,
           return_rate,
           ROW_NUMBER() OVER (ORDER BY return_rate DESC) AS rank,
           review_score,
           comment_count
    FROM category_seller_stats
),

canceled_order_reviews AS (
    SELECT r.review_score,
           COUNT(*) AS comment_count
    FROM ne_orders o
    JOIN order_reviews r ON o.order_id = r.order_id
    WHERE o.order_status = 'canceled'
    GROUP BY r.review_score
),
review_dist AS (
